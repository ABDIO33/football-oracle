  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "cloudflare-ai": {
      "type": "local",
      "command": ["python", "cloudflare_ai_mcp.py"],
      "enabled": true
    }
  }
}
